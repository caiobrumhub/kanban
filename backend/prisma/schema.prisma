// Prisma schema — Kanban Board
// Banco: MySQL | Generator: prisma-client-js

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Role {
  USER
  ADMIN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  password       String
  role           Role          @default(USER)
  isActive       Boolean       @default(true)
  refreshToken   String?       @db.Text
  lastLogin      DateTime?
  shareCode      String?       @unique @default(cuid())
  boards         Board[]
  sharedBoards   SharedBoard[]
  createdClients Client[]      @relation("ClientCreator")
  updatedClients Client[]      @relation("ClientUpdater")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Board {
  id         Int           @id @default(autoincrement())
  title      String
  color      String?       @default("bg-primary-500")
  icon       String?       @default("fi-rr-chalkboard")
  userId     Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns    Column[]
  sharedWith SharedBoard[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model SharedBoard {
  id        Int      @id @default(autoincrement())
  boardId   Int
  userId    Int
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([boardId, userId])
}

model Column {
  id        Int      @id @default(autoincrement())
  title     String
  order     Int      @default(0)
  boardId   Int
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id          Int         @id @default(autoincrement())
  title       String
  description String?     @db.Text
  priority    Priority    @default(MEDIUM)
  order       Int         @default(0)
  isDone      Boolean     @default(false)
  columnId    Int
  column      Column      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  clientId    Int?
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  labels      Label[]
  checklists  Checklist[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Label {
  id     Int    @id @default(autoincrement())
  name   String
  color  String @default("#6366f1")
  cardId Int
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model SystemParameter {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model Client {
  id                Int      @id @default(autoincrement())
  name              String
  document          String? // CPF ou CNPJ
  stateRegistration String?  @default("ISENTO") // Inscrição Estadual
  email             String?
  phone             String?
  zipCode           String?
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  
  createdById       Int?
  createdBy         User?    @relation("ClientCreator", fields: [createdById], references: [id])
  updatedById       Int?
  updatedBy         User?    @relation("ClientUpdater", fields: [updatedById], references: [id])
  
  cards             Card[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Checklist {
  id        Int             @id @default(autoincrement())
  title     String
  cardId    Int
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ChecklistItem {
  id          Int       @id @default(autoincrement())
  text        String
  isCompleted Boolean   @default(false)
  isMandatory Boolean   @default(false)
  checklistId Int
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
